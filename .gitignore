# =========================
# OS GENERATED FILES
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =========================
# ANDROID & GRADLE FILES
# =========================
# Built application files
*.apk
*.ap_
*.aab

# Local configuration file (hides your specific computer paths)
local.properties

# Gradle cache and build folders
.gradle/
build/
*/build/
*/*/build/

# IDE files (Android Studio)
.idea/
*.iml
*.iws

# =========================
# PYTHON & DOCKER FILES
# =========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments (just in case you ever run it locally without Docker)
venv/
env/
.env

# Database files
*.sqlite3
postgres_data/

# Docker overrides
docker-compose.override.yml
