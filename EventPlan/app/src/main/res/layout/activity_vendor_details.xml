<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivDetailVendorPic"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#EEEEEE" />

    <TextView
        android:id="@+id/tvDetailName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDetailLocPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="#666666"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvDetailDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnRevealCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Check Availability &amp; Book"
        android:textSize="18sp"
        android:padding="16dp"/>

    <LinearLayout
        android:id="@+id/layoutBookingSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="16dp">

        <CalendarView
            android:id="@+id/calendarClientBooking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"/>

        <TextView
            android:id="@+id/tvBookingStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select a date."
            android:textSize="16sp"
            android:padding="8dp"
            android:textAlignment="center"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnConfirmBooking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm Booking"
            android:backgroundTint="#4CAF50"
            android:enabled="false"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

</LinearLayout>