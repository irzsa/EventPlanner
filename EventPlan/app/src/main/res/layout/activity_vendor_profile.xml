<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvHubVendorName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:textStyle="bold"
        android:text="Loading..." />

    <TextView
        android:id="@+id/tvHubVendorDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnEditVendorProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit Business Details"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Master Calendar"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <CalendarView
        android:id="@+id/calendarVendorHub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F5F5"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvSelectedDateStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:text="Click a date to see its status."
        android:padding="16dp"
        android:background="#E0E0E0"
        android:textAlignment="center"/>

</LinearLayout>